---
import type {
    BadgeColors,
    BadgeTypes,
    Sizes,
} from "@/components/base/badges/badge-types";
import { badgeTypes } from "@/components/base/badges/badge-types";
import { withPillTypes } from "@/components/base/badges/badge-colors";

interface Props {
    type?: BadgeTypes;
    size?: Sizes;
    color?: BadgeColors;
    imgSrc: string;
}

const {
    type = "pill-color",
    size = "md",
    color = "gray",
    imgSrc,
} = Astro.props;

const colors = withPillTypes[type];

const pillSizes = {
    sm: "gap-1 py-0.5 pl-0.75 pr-2 text-xs font-medium",
    md: "gap-1.5 py-0.5 pl-1 pr-2.5 text-sm font-medium",
    lg: "gap-1.5 py-1 pl-1.5 pr-3 text-sm font-medium",
};
const badgeSizes = {
    sm: "gap-1 py-0.5 pl-1 pr-1.5 text-xs font-medium",
    md: "gap-1.5 py-0.5 pl-1.5 pr-2 text-sm font-medium",
    lg: "gap-1.5 py-1 pl-2 pr-2.5 text-sm font-medium rounded-lg",
};

const sizeMap = {
    [badgeTypes.pillColor]: pillSizes,
    [badgeTypes.badgeColor]: badgeSizes,
    [badgeTypes.badgeModern]: badgeSizes,
};
---

<span
    class:list={[
        colors.common,
        sizeMap[type][size],
        colors.styles[color]?.root,
    ]}
>
    <img
        src={imgSrc}
        class="size-4 max-w-none rounded-full"
        alt="Badge image"
    />
    <slot />
</span>
