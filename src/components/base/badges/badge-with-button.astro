---
import type {
    BadgeColors,
    BadgeTypes,
    IconComponentType,
    Sizes,
} from "@/components/base/badges/badge-types";
import { badgeTypes } from "@/components/base/badges/badge-types";
import { withPillTypes } from "@/components/base/badges/badge-colors";
import { X as CloseX } from "@untitledui/icons";

interface Props {
    type?: BadgeTypes;
    size?: Sizes;
    color?: BadgeColors;
    icon?: IconComponentType;
    /**
     * Etiqueta accesible del botón.
     */
    buttonLabel?: string;
}

const {
    type = "pill-color",
    size = "md",
    color = "gray",
    icon: Icon = CloseX,
    buttonLabel,
} = Astro.props;

const colors = withPillTypes[type];

const pillSizes = {
    sm: "gap-0.5 py-0.5 pl-2 pr-0.75 text-xs font-medium",
    md: "gap-0.5 py-0.5 pl-2.5 pr-1 text-sm font-medium",
    lg: "gap-0.5 py-1 pl-3 pr-1.5 text-sm font-medium",
};
const badgeSizes = {
    sm: "gap-0.5 py-0.5 pl-1.5 pr-0.75 text-xs font-medium",
    md: "gap-0.5 py-0.5 pl-2 pr-1 text-sm font-medium",
    lg: "gap-0.5 py-1 pl-2.5 pr-1.5 text-sm font-medium rounded-lg",
};

const sizeMap = {
    [badgeTypes.pillColor]: pillSizes,
    [badgeTypes.badgeColor]: badgeSizes,
    [badgeTypes.badgeModern]: badgeSizes,
};

const buttonRoundedClass =
    type === "pill-color" ? "rounded-full" : "rounded-[3px]";
---

<span
    class:list={[
        colors.common,
        sizeMap[type][size],
        colors.styles[color]?.root,
    ]}
>
    <slot />
    <button
        type="button"
        aria-label={buttonLabel}
        onclick="this.dispatchEvent(new CustomEvent('badge-dismiss', { bubbles: true, composed: true }))"
        class:list={[
            "flex cursor-pointer items-center justify-center p-0.5 outline-focus-ring transition duration-100 ease-linear focus-visible:outline-2",
            colors.styles[color]?.addonButton,
            buttonRoundedClass,
        ]}
    >
        <Icon class="size-3 stroke-[3px] transition-inherit-all" />
    </button>
</span>
