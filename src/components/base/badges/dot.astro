---
interface Props {
    size?: "sm" | "md";
    class?: string;
}

const sizes = {
    sm: { wh: 8, c: 4, r: 2.5 },
    md: { wh: 10, c: 5, r: 4 },
};

const { size = "md", class: className } = Astro.props;
const s = sizes[size];
---

<svg
    width={s.wh}
    height={s.wh}
    viewBox={`0 0 ${s.wh} ${s.wh}`}
    fill="none"
    class={className}
>
    <circle cx={s.c} cy={s.c} r={s.r} fill="currentColor" stroke="currentColor"
    ></circle>
</svg>
